{
  "permissions": {
    "allow": [
      "Read(//dls_sw/**)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": []
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "skipAutoPermissionPrompt": true
}